{
  "openapi": "3.1.0",
  "info": {
    "title": "Mneme REST API Draft",
    "version": "0.1.0-draft",
    "description": "Shared REST contract served by both the Python (FastAPI) and Go runtimes. All routes are mounted under the /api/v1 prefix. Response field names are language-neutral; where the Go runtime cannot yet compute a field it returns a documented default (created_at: \"\", retention_state: \"active\", explanation: null) rather than omitting it."
  },
  "paths": {
    "/api/v1/health": {
      "get": {
        "tags": ["health"],
        "summary": "Service health",
        "responses": {
          "200": {
            "description": "Service health",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {"status": {"type": "string", "const": "ok"}},
                  "required": ["status"],
                  "additionalProperties": false
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/query/search": {
      "post": {
        "tags": ["query"],
        "summary": "Hybrid search over Mneme memory",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchRequest"}}}
        },
        "responses": {
          "200": {
            "description": "Ranked search results",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SearchResponse"}}}
          },
          "405": {"description": "Method not allowed"}
        }
      }
    },
    "/api/v1/query/timeline": {
      "post": {
        "tags": ["query"],
        "summary": "Chronological timeline query",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimelineRequest"}}}
        },
        "responses": {
          "200": {
            "description": "Timeline points ordered ascending by sequence",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/TimelineResponse"}}}
          },
          "405": {"description": "Method not allowed"}
        }
      }
    },
    "/api/v1/visualizations/graph": {
      "post": {
        "tags": ["visualizations"],
        "summary": "Graph projection for query results",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GraphRequest"}}}
        },
        "responses": {
          "200": {
            "description": "Nodes and edges derived from search hits",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/GraphResponse"}}}
          },
          "405": {"description": "Method not allowed"}
        }
      }
    },
    "/api/v1/jsonrpc": {
      "post": {
        "tags": ["jsonrpc"],
        "summary": "JSON-RPC 2.0 over HTTP (full Mneme method set)",
        "description": "Dispatches to the same method set as the stdio JSON-RPC transport. JSON-RPC-level errors are returned as an error object with HTTP status 200.",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JsonRpcRequest"}}}
        },
        "responses": {
          "200": {
            "description": "JSON-RPC 2.0 response envelope (result or error).",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/JsonRpcResponse"}}}
          }
        }
      }
    },
    "/api/v1/memory/episode": {
      "post": {
        "tags": ["write"],
        "summary": "Add an episode memory",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AddEpisodeRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The created commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    },
    "/api/v1/memory/fact": {
      "post": {
        "tags": ["write"],
        "summary": "Add a fact memory",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/AddFactRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The created commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    },
    "/api/v1/memory/commit": {
      "post": {
        "tags": ["write"],
        "summary": "Append a raw memory commit",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The created commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    },
    "/api/v1/memory/fact/invalidate": {
      "post": {
        "tags": ["write"],
        "summary": "Invalidate an existing fact",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/InvalidateFactRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The invalidation commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    },
    "/api/v1/subjects": {
      "post": {
        "tags": ["write"],
        "summary": "Create or update a subject",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UpsertSubjectRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The upserted subject",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SubjectSummary"}}}
          }
        }
      }
    },
    "/api/v1/entities": {
      "post": {
        "tags": ["write"],
        "summary": "Create or update an entity",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/UpsertEntityRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The upserted entity",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/EntitySummary"}}}
          }
        }
      }
    },
    "/api/v1/branches": {
      "post": {
        "tags": ["write"],
        "summary": "Create a branch",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CreateBranchRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The created branch head",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/BranchHeadSummary"}}}
          }
        }
      }
    },
    "/api/v1/branches/merge": {
      "post": {
        "tags": ["write"],
        "summary": "Merge a source branch into a target branch",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/MergeBranchRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The merge commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    },
    "/api/v1/extract": {
      "post": {
        "tags": ["write"],
        "summary": "Extract derived commits from a stored episode",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ExtractEpisodeRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The extraction run",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/ExtractionRun"}}}
          }
        }
      }
    },
    "/api/v1/commits/retention": {
      "post": {
        "tags": ["write"],
        "summary": "Set the retention state of a commit",
        "requestBody": {
          "required": true,
          "content": {"application/json": {"schema": {"$ref": "#/components/schemas/SetRetentionStateRequest"}}}
        },
        "responses": {
          "200": {
            "description": "The updated commit",
            "content": {"application/json": {"schema": {"$ref": "#/components/schemas/CommitSummary"}}}
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SearchRequest": {
        "type": "object",
        "description": "Filter surface for hybrid search. The Python reference runtime honors every filter; the Go runtime currently applies query, branch_name, entity_ids, and top_k.",
        "properties": {
          "query": {"type": ["string", "null"]},
          "branch_name": {"type": "string", "default": "main"},
          "snapshot_id": {"type": ["string", "null"]},
          "subject_scope": {"type": ["string", "null"]},
          "owner_subject_id": {"type": ["string", "null"]},
          "participant_subject_ids": {"type": "array", "items": {"type": "string"}},
          "entity_ids": {"type": "array", "items": {"type": "string"}},
          "object_ids": {"type": "array", "items": {"type": "string"}},
          "object_types": {"type": "array", "items": {"type": "string"}},
          "cognitive_profile_id": {"type": ["string", "null"]},
          "memory_types": {"type": "array", "items": {"type": "string"}},
          "epistemic_status": {"type": ["string", "null"]},
          "contradiction_status": {"type": ["string", "null"]},
          "retention_states": {"type": ["array", "null"], "items": {"type": "string"}},
          "modes": {"type": "array", "items": {"type": "string"}, "default": ["structured", "lexical", "semantic", "relation"]},
          "top_k": {"type": "integer", "default": 20},
          "candidate_limit": {"type": ["integer", "null"]},
          "include_explanations": {"type": "boolean", "default": false}
        }
      },
      "SearchResponse": {
        "type": "object",
        "properties": {"items": {"type": "array", "items": {"$ref": "#/components/schemas/SearchResultItem"}}},
        "required": ["items"]
      },
      "SearchResultItem": {
        "type": "object",
        "properties": {
          "commit": {"$ref": "#/components/schemas/CommitSummary"},
          "score": {"type": "number"},
          "matched_modes": {"type": "array", "items": {"type": "string"}},
          "explanation": {"oneOf": [{"$ref": "#/components/schemas/SearchExplanationSummary"}, {"type": "null"}]}
        },
        "required": ["commit", "score", "matched_modes", "explanation"]
      },
      "SearchExplanationSummary": {
        "type": "object",
        "description": "Populated only by runtimes with explanation support (Python). The Go runtime returns null.",
        "properties": {
          "matched_modes": {"type": "array", "items": {"type": "string"}},
          "score_breakdown": {"type": "object", "additionalProperties": {"type": "number"}},
          "matched_filters": {"type": "object"},
          "reasons": {"type": "array", "items": {"type": "string"}},
          "lineage": {"type": "array", "items": {"type": "string"}}
        }
      },
      "CommitSummary": {
        "type": "object",
        "description": "Language-neutral commit projection. created_at and retention_state are defaulted by runtimes that do not yet track them (Go returns \"\" and \"active\").",
        "properties": {
          "commit_id": {"type": "string"},
          "sequence": {"type": "integer"},
          "memory_type": {"type": "string"},
          "branch_name": {"type": "string"},
          "created_at": {"type": "string"},
          "retention_state": {"type": "string"},
          "payload": {"type": "object"},
          "metadata": {"type": "object"}
        },
        "required": ["commit_id", "sequence", "memory_type", "branch_name", "created_at", "retention_state", "payload", "metadata"]
      },
      "TimelineRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "snapshot_id": {"type": ["string", "null"]},
          "subject_scope": {"type": ["string", "null"]},
          "owner_subject_id": {"type": ["string", "null"]},
          "participant_subject_ids": {"type": "array", "items": {"type": "string"}},
          "entity_ids": {"type": "array", "items": {"type": "string"}},
          "object_ids": {"type": "array", "items": {"type": "string"}},
          "object_types": {"type": "array", "items": {"type": "string"}},
          "memory_types": {"type": "array", "items": {"type": "string"}},
          "epistemic_status": {"type": ["string", "null"]},
          "contradiction_status": {"type": ["string", "null"]},
          "retention_states": {"type": ["array", "null"], "items": {"type": "string"}},
          "limit": {"type": "integer", "default": 100}
        }
      },
      "TimelineResponse": {
        "type": "object",
        "properties": {"items": {"type": "array", "items": {"$ref": "#/components/schemas/TimelinePoint"}}},
        "required": ["items"]
      },
      "TimelinePoint": {
        "type": "object",
        "description": "Flat chronological point. Not nested under a commit object.",
        "properties": {
          "commit_id": {"type": "string"},
          "sequence": {"type": "integer"},
          "memory_type": {"type": "string"},
          "branch_name": {"type": "string"},
          "created_at": {"type": "string"},
          "label": {"type": "string"},
          "metadata": {"type": "object"}
        },
        "required": ["commit_id", "sequence", "memory_type", "branch_name", "created_at", "label", "metadata"]
      },
      "GraphRequest": {
        "allOf": [{"$ref": "#/components/schemas/SearchRequest"}],
        "description": "Identical filter surface to SearchRequest; include_explanations defaults to true."
      },
      "GraphResponse": {
        "type": "object",
        "properties": {
          "nodes": {"type": "array", "items": {"$ref": "#/components/schemas/GraphNode"}},
          "edges": {"type": "array", "items": {"$ref": "#/components/schemas/GraphEdge"}}
        },
        "required": ["nodes", "edges"]
      },
      "GraphNode": {
        "type": "object",
        "description": "kind is one of commit, subject, entity, object. The Go runtime emits commit and entity nodes; subject and object nodes require explanation support (Python).",
        "properties": {
          "id": {"type": "string"},
          "label": {"type": "string"},
          "kind": {"type": "string"},
          "metadata": {"type": "object"}
        },
        "required": ["id", "label", "kind", "metadata"]
      },
      "GraphEdge": {
        "type": "object",
        "description": "kind is one of subject_link, entity_link, object_link, relation. The Go runtime emits entity_link edges from commit entity links.",
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "label": {"type": "string"},
          "kind": {"type": "string"},
          "metadata": {"type": "object"}
        },
        "required": ["source", "target", "label", "kind", "metadata"]
      },
      "JsonRpcRequest": {
        "type": "object",
        "description": "JSON-RPC 2.0 request envelope. method is a Mneme method name such as mneme.add_episode; params is the method's argument object.",
        "properties": {
          "jsonrpc": {"type": "string", "const": "2.0"},
          "id": {"type": ["string", "integer", "null"]},
          "method": {"type": "string"},
          "params": {"type": "object"}
        },
        "required": ["jsonrpc", "method"]
      },
      "JsonRpcResponse": {
        "type": "object",
        "description": "JSON-RPC 2.0 response envelope. Exactly one of result or error is present.",
        "properties": {
          "jsonrpc": {"type": "string", "const": "2.0"},
          "id": {"type": ["string", "integer", "null"]},
          "result": {},
          "error": {
            "type": "object",
            "properties": {
              "code": {"type": "integer"},
              "message": {"type": "string"},
              "data": {}
            },
            "required": ["code", "message"]
          }
        },
        "required": ["jsonrpc", "id"]
      },
      "AddEpisodeRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "content": {"type": "string"},
          "episode_type": {"type": ["string", "null"]},
          "source": {"type": ["string", "null"]},
          "observed_at": {"type": ["string", "null"]},
          "tenant_id": {"type": "string", "default": "default"},
          "project_id": {"type": "string", "default": "default"}
        },
        "required": ["content"]
      },
      "AddFactRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "fact_id": {"type": "string"},
          "subject_id": {"type": "string"},
          "predicate": {"type": "string"},
          "object_value": {"type": "string"},
          "valid_from": {"type": ["string", "null"]},
          "valid_to": {"type": ["string", "null"]},
          "confidence": {"type": "number", "default": 1.0},
          "tenant_id": {"type": "string", "default": "default"},
          "project_id": {"type": "string", "default": "default"}
        },
        "required": ["fact_id", "subject_id", "predicate", "object_value"]
      },
      "CommitRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "memory_type": {"type": "string"},
          "payload": {"type": "object"},
          "metadata": {"type": "object"},
          "owner_subject_id": {"type": ["string", "null"]},
          "tenant_id": {"type": "string", "default": "default"},
          "project_id": {"type": "string", "default": "default"}
        },
        "required": ["memory_type"]
      },
      "InvalidateFactRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "fact_id": {"type": "string"},
          "invalidated_at": {"type": "string"},
          "reason": {"type": ["string", "null"]}
        },
        "required": ["fact_id", "invalidated_at"]
      },
      "UpsertSubjectRequest": {
        "type": "object",
        "properties": {
          "subject_id": {"type": "string"},
          "subject_type": {"type": "string"},
          "display_name": {"type": ["string", "null"]}
        },
        "required": ["subject_id", "subject_type"]
      },
      "UpsertEntityRequest": {
        "type": "object",
        "properties": {
          "entity_id": {"type": "string"},
          "entity_type": {"type": "string"},
          "canonical_name": {"type": ["string", "null"]},
          "metadata": {"type": "object"}
        },
        "required": ["entity_id", "entity_type"]
      },
      "CreateBranchRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string"},
          "from_branch": {"type": ["string", "null"], "default": "main"}
        },
        "required": ["branch_name"]
      },
      "MergeBranchRequest": {
        "type": "object",
        "description": "strategy is one of manual, ours, theirs.",
        "properties": {
          "source_branch": {"type": "string"},
          "target_branch": {"type": "string", "default": "main"},
          "strategy": {"type": "string", "default": "manual"}
        },
        "required": ["source_branch"]
      },
      "ExtractEpisodeRequest": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string", "default": "main"},
          "episode_commit_id": {"type": "string"},
          "provider": {"type": "string", "default": "offline"}
        },
        "required": ["episode_commit_id"]
      },
      "SetRetentionStateRequest": {
        "type": "object",
        "description": "retention_state is one of hot, warm, cold, frozen, tombstoned.",
        "properties": {
          "commit_id": {"type": "string"},
          "retention_state": {"type": "string"}
        },
        "required": ["commit_id", "retention_state"]
      },
      "SubjectSummary": {
        "type": "object",
        "properties": {
          "subject_id": {"type": "string"},
          "subject_type": {"type": "string"},
          "display_name": {"type": ["string", "null"]}
        },
        "required": ["subject_id", "subject_type"]
      },
      "EntitySummary": {
        "type": "object",
        "properties": {
          "entity_id": {"type": "string"},
          "entity_type": {"type": "string"},
          "canonical_name": {"type": ["string", "null"]}
        },
        "required": ["entity_id", "entity_type"]
      },
      "BranchHeadSummary": {
        "type": "object",
        "properties": {
          "branch_name": {"type": "string"},
          "head_commit_id": {"type": ["string", "null"]},
          "head_sequence": {"type": "integer"},
          "parent_branch_name": {"type": ["string", "null"]},
          "status": {"type": "string"}
        },
        "required": ["branch_name", "head_sequence", "status"]
      },
      "ExtractionRun": {
        "type": "object",
        "properties": {
          "run_id": {"type": "string"},
          "episode_commit_id": {"type": "string"},
          "branch_name": {"type": "string"},
          "provider_id": {"type": "string"},
          "fingerprint": {"type": "string"},
          "status": {"type": "string"},
          "derived_commit_ids": {"type": "array", "items": {"type": "string"}},
          "error": {"type": ["string", "null"]}
        },
        "required": ["run_id", "episode_commit_id", "branch_name", "provider_id", "fingerprint", "status", "derived_commit_ids"]
      }
    }
  }
}
