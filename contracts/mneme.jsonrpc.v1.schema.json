{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "https://mneme.local/contracts/mneme.jsonrpc.v1.schema.json",
    "title":  "Mneme JSON-RPC V1",
    "oneOf":  [
                  {
                      "$ref":  "#/$defs/request"
                  },
                  {
                      "$ref":  "#/$defs/success_response"
                  },
                  {
                      "$ref":  "#/$defs/error_response"
                  }
              ],
    "$defs":  {
                  "request":  {
                                  "type":  "object",
                                  "required":  [
                                                   "jsonrpc",
                                                   "id",
                                                   "method",
                                                   "params"
                                               ],
                                  "properties":  {
                                                     "jsonrpc":  {
                                                                     "const":  "2.0"
                                                                 },
                                                     "id":  {
                                                                "type":  [
                                                                             "string",
                                                                             "integer",
                                                                             "null"
                                                                         ]
                                                            },
                                                     "method":  {
                                                                    "type":  "string",
                                                                    "enum":  [
                                                                                 "mneme.upsert_subject",
                                                                                 "mneme.upsert_entity",
                                                                                 "mneme.resolve_entity",
                                                                                 "mneme.resolve_entity_explained",
                                                                                 "mneme.add_episode",
                                                                                 "mneme.commit_memory",
                                                                                 "mneme.add_fact",
                                                                                 "mneme.invalidate_fact",
                                                                                 "mneme.query_facts",
                                                                                 "mneme.query_memories",
                                                                                 "mneme.search_memory",
                                                                                 "mneme.create_branch",
                                                                                 "mneme.merge_branch"
                                                                             ]
                                                                },
                                                     "params":  {
                                                                    "type":  "object",
                                                                    "additionalProperties":  true
                                                                }
                                                 },
                                  "additionalProperties":  false
                              },
                  "success_response":  {
                                           "type":  "object",
                                           "required":  [
                                                            "jsonrpc",
                                                            "id",
                                                            "result"
                                                        ],
                                           "properties":  {
                                                              "jsonrpc":  {
                                                                              "const":  "2.0"
                                                                          },
                                                              "id":  {
                                                                         "type":  [
                                                                                      "string",
                                                                                      "integer",
                                                                                      "null"
                                                                                  ]
                                                                     },
                                                              "result":  {

                                                                         }
                                                          },
                                           "additionalProperties":  false
                                       },
                  "error_response":  {
                                         "type":  "object",
                                         "required":  [
                                                          "jsonrpc",
                                                          "id",
                                                          "error"
                                                      ],
                                         "properties":  {
                                                            "jsonrpc":  {
                                                                            "const":  "2.0"
                                                                        },
                                                            "id":  {
                                                                       "type":  [
                                                                                    "string",
                                                                                    "integer",
                                                                                    "null"
                                                                                ]
                                                                   },
                                                            "error":  {
                                                                          "type":  "object",
                                                                          "required":  [
                                                                                           "code",
                                                                                           "message"
                                                                                       ],
                                                                          "properties":  {
                                                                                             "code":  {
                                                                                                          "type":  "integer"
                                                                                                      },
                                                                                             "message":  {
                                                                                                             "type":  "string"
                                                                                                         },
                                                                                             "data":  {

                                                                                                      }
                                                                                         },
                                                                          "additionalProperties":  false
                                                                      }
                                                        },
                                         "additionalProperties":  false
                                     }
              }
}
