{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mneme.local/contracts/mneme.memory.v1.schema.json",
  "title": "Mneme Memory Operation Fixture V1",
  "type": "object",
  "required": ["contract_version", "name", "steps"],
  "properties": {
    "contract_version": {
      "const": "mneme.memory.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "type": "object",
      "required": ["id", "method", "params"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "mneme.upsert_subject",
            "mneme.upsert_entity",
            "mneme.resolve_entity",
            "mneme.resolve_entity_explained",
            "mneme.add_episode",
            "mneme.commit_memory",
            "mneme.add_fact",
            "mneme.invalidate_fact",
            "mneme.query_facts",
            "mneme.query_memories",
            "mneme.search_memory",
            "mneme.create_branch",
            "mneme.merge_branch"
          ]
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        },
        "expect": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  }
}
