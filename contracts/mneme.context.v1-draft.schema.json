{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axisrobo.github.io/Mneme/mneme.context.v1-draft.schema.json",
  "title": "Mneme Context Assembly v1 Draft",
  "type": "object",
  "required": ["query", "budget", "sections", "omitted"],
  "properties": {
    "query": {"type": "string"},
    "budget": {"type": "integer", "minimum": 0},
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section", "items"],
        "properties": {
          "section": {"type": "string"},
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text", "source_id", "reason"],
              "properties": {
                "text": {"type": "string"},
                "source_id": {"type": "string"},
                "reason": {"type": "string"},
                "access": {"type": "object"}
              }
            }
          }
        }
      }
    },
    "omitted": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "reason"],
        "properties": {
          "source_id": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    }
  }
}
