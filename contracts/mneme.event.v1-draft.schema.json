{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mneme.event.v1-draft",
  "title": "Mneme Event Envelope",
  "description": "Shared event envelope for memory lifecycle events across Python and Go runtimes.",
  "type": "object",
  "required": ["event_id", "event_type", "timestamp"],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Unique event identifier"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "commit:stored",
        "commit:indexed",
        "entity:upserted",
        "fact:stored",
        "fact:invalidated",
        "episode:stored",
        "extraction:queued",
        "extraction:complete",
        "branch:created",
        "branch:merged"
      ]
    },
    "commit_id": {
      "type": "string",
      "description": "Commit identifier, present for commit and fact events"
    },
    "branch_name": {
      "type": "string",
      "description": "Branch name the event occurred on"
    },
    "memory_type": {
      "type": "string",
      "description": "Memory type (episode, fact, event, knowledge, etc.)"
    },
    "entity_id": {
      "type": "string",
      "description": "Entity identifier, present for entity events"
    },
    "fact_id": {
      "type": "string",
      "description": "Fact identifier, present for fact events"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of event occurrence"
    },
    "metadata": {
      "type": "object",
      "description": "Additional context key-value pairs"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific data payload"
    }
  }
}
