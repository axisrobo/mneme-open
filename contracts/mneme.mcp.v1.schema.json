{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "https://mneme.local/contracts/mneme.mcp.v1.schema.json",
    "title":  "Mneme MCP V1 Tool Contract",
    "type":  "object",
    "required":  [
                     "contract_version",
                     "tools"
                 ],
    "properties":  {
                       "contract_version":  {
                                                "const":  "mneme.mcp.v1"
                                            },
                       "tools":  {
                                     "type":  "array",
                                     "items":  {
                                                   "$ref":  "#/$defs/tool"
                                               }
                                 }
                   },
    "additionalProperties":  false,
    "$defs":  {
                  "tool":  {
                               "type":  "object",
                               "required":  [
                                                "name",
                                                "input_schema"
                                            ],
                               "properties":  {
                                                  "name":  {
                                                               "type":  "string",
                                                               "enum":  [
                                                                            "mneme.upsert_subject",
                                                                            "mneme.upsert_entity",
                                                                            "mneme.resolve_entity",
                                                                            "mneme.resolve_entity_explained",
                                                                            "mneme.add_episode",
                                                                            "mneme.commit_memory",
                                                                            "mneme.add_fact",
                                                                            "mneme.invalidate_fact",
                                                                            "mneme.query_facts",
                                                                            "mneme.query_memories",
                                                                            "mneme.search_memory",
                                                                            "mneme.create_branch",
                                                                            "mneme.merge_branch"
                                                                        ],
                                                               "pattern":  "^mneme\\.[a-z_]+"
                                                           },
                                                  "input_schema":  {
                                                                       "type":  "object",
                                                                       "additionalProperties":  true
                                                                   }
                                              },
                               "additionalProperties":  false
                           }
              }
}
